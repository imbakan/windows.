IDI_SMALL               ICON         "small.ico"

/////////////////////////////////////////////////////////////////////////////
//
// Menu
//

IDC_SCRGENOPENGL MENU
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "E&xit",                IDM_EXIT
    END
    POPUP "&Edit"
    BEGIN
        MENUITEM "&Copy\tCtrl+C",        IDM_COPY
        MENUITEM "&Paste\tCtrl+V",       IDM_PASTE
    END
    POPUP "Tools"
    BEGIN
        POPUP "Generate"
        BEGIN
            MENUITEM "Header File",     IDM_GENERATE_H
            MENUITEM "Source File",     IDM_GENERATE_CPP
        END
    END
END


